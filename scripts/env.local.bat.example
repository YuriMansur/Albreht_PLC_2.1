@echo off
rem ============================================================================
rem ШАБЛОН per-machine настроек. Скопируй в env.local.bat (без .example) и правь.
rem env.local.bat НЕ версионируется (в .gitignore) — у каждой машины свой.
rem Нужен только если автопоиск в _find_codesys.bat не справился.
rem ============================================================================

rem Полный путь к CODESYS.exe (обычно ...\CODESYS\Common\CODESYS.exe):
rem set "CODESYS=C:\Program Files\CODESYS 3.5.17.30\CODESYS\Common\CODESYS.exe"

rem Имя профиля (CODESYS -> Help/About, либо имя файла в
rem %ProgramData%\CODESYS\Profiles\*.profile без расширения):
rem set "PROFILE=CODESYS V3.5 SP17 Patch 3"
