          <action name="MainAlgorithm">
            <body>
              <ST>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">	(*
	// Движение вниз циклично
	fbMoveRelative(
	Axis:= Y_Axis, 
	Execute:= (bExecuteMR OR fbGenSQR_Q) AND bPuskMR, 
	Distance:= lrDistanceMR_PLUS, 
	Velocity:= lrVelocityMR, 
	Acceleration:= lrAccelerationMR, 
	Deceleration:= lrDecelerationMR, 
	Jerk:= , 
	BufferMode:= , 
	Done=&gt; , 
	Busy=&gt; , 
	Active=&gt; , 
	CommandAborted=&gt; , 
	Error=&gt; , 
	ErrorID=&gt; );
	
	// Движение вверх циклично
	fbMoveRelative2(
	Axis:= Y_Axis, 
	Execute:= (bExecuteMR OR NOT fbGenSQR_Q) AND bPuskMR, 
	Distance:= lrDistanceMR_MINUS, 
	Velocity:= lrVelocityMR, 
	Acceleration:= lrAccelerationMR, 
	Deceleration:= lrDecelerationMR, 
	Jerk:= , 
	BufferMode:= , 
	Done=&gt; , 
	Busy=&gt; , 
	Active=&gt; , 
	CommandAborted=&gt; , 
	Error=&gt; , 
	ErrorID=&gt; );
	*)

	// Движение согласно закону (Квадратично/Синусоидально)
	fbFollowPosition(
	Axis:= Y_Axis, 
	bExecute:= bExecuteFP, 
	//fSetPosition:= lrfSetPositionFP + lrTMP_PLUS_MINUS, 
	fSetPosition:= lrfSetPositionFP + OUT,  //текущая позиция + отклонение согласно квадратично/синусоидальному закону 
	bBusy=&gt; , 
	bCommandAborted=&gt; , 
	bError=&gt; , 
	iErrorID=&gt; );
	
	//При нажатии на кнопку "btn" фиксируем текущую позицию
	r_trig123(CLK := ServoControl.btn);
	IF r_trig123.Q THEN
	lrfSetPositionFP := lrCurrentPosition;    	
	END_IF
	
	//Текущая позиция
	fbReadActualPosition(
	Axis:= Y_Axis, 
	Enable:= TRUE, 
	Valid=&gt; , 
	Busy=&gt; , 
	Error=&gt; , 
	ErrorID=&gt; , 
	Position=&gt; lrCurrentPosition);

	//bSelect_gen_signal_btn - 0 -&gt; SIN, bSelect_gen_signal_btn - 1 -&gt; SQR 
	IF bSelect_gen_signal_btn THEN
	///////КВАДРАТ/////////////////
	fbGenSQR(
	PT:= _PT, 
	AM:= _AM, 
	OS:= _OS, 
	DC:= _DC, 
	DL:= _DL, 
	Q=&gt; fbGenSQR_Q, 
	Out=&gt; OUT);
	
	IF fbGenSQR_Q = TRUE THEN
		GenSignalOUT_TMP := OUT;
		lrDistanceMR_PLUS := PLUS;
		lrTMP_PLUS_MINUS := PLUS;
	END_IF
	
	IF fbGenSQR_Q = FALSE THEN
		GenSignalOUT_TMP := 0;
		lrDistanceMR_MINUS := MINUS;
		lrTMP_PLUS_MINUS := MINUS;
	END_IF
	
	fbFreq_Measure(
	IN:= fbGenSQR_Q, 
	PERIODS:= 1, 
	RESET:= fbFreq_Measure_reset, 
	OUT=&gt; fbFreq_Measure_current_freq, 
	VALID=&gt; fbFreq_Measure_valid);
	ELSE
	//////////////СИНУС////////////////////	
	fbGen_SIN(
	PT:= _PT, 
	AM:= _AM, 
	OS:= _OS, 
	DL:= _DL, 
	Q=&gt; fbGen_SIN_Q, 
	Out=&gt; OUT);
		
	IF fbGen_SIN_Q = TRUE THEN
		GenSignalOUT_TMP := OUT;
	END_IF
	
	IF fbGen_SIN_Q = FALSE THEN
		GenSignalOUT_TMP := 0;
	END_IF
	
	//Частота в Гц
	fbFreq_Measure(
	IN:= fbGen_SIN_Q, 
	PERIODS:= 1, 
	RESET:= fbFreq_Measure_reset, 
	OUT=&gt; fbFreq_Measure_current_freq, 
	VALID=&gt; fbFreq_Measure_valid);
	END_IF
	//////////////////////////////////////////////////////////////////////////////
	(*
	out_after_offset := OSCAT_BASIC.OFFSET(
	X:= GenSignalOUT_TMP, 
	O1:= TRUE, 
	O2:= FALSE, 
	O3:= FALSE, 
	O4:= FALSE, 
	D:= FALSE, 
	Offset_1:= offset_1,
	Offset_2:= 0,
	Offset_3:= 0,
	Offset_4:= 0,
	default:= 0);   *)

//Переводим условные единицы в мм
fbLinearSensorHandle(position := GVL.KTSL_Position_1, Calc_position_mm =&gt; mm);

//мм в юниты   Заменить mm_tmp на mm
fbLIN_TRAFO_0(
	IN:= mm, 
	IN_MIN:= 0, 
	IN_MAX:= 1000, 
	OUT_MIN:= -1666611.98, 
	OUT_MAX:= -1521270.48, 
	OUT=&gt; units, 
	ERROR=&gt; );

// Преобразование ГЦ во время _PT
_PT := real_TO_TIME(EXPT(ustavka_HERZ, -1) * 1000);

// Задать диапазон отклонения сигнала 
_AM := ustavka_H * 2;




</xhtml>
              </ST>
            </body>
            <addData />
          </action>
          <action name="Jog">
            <body>
              <ST>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">IF NOT ReadFBErrorError AND fbPower.Status THEN



fbJog(
	Axis:= Y_Axis, 
	JogForward:= GVL.bfbJogJogForward,   // против часовой (+ ServoControl.LrPosition_readActPos)  ВНИЗ
	JogBackward:= GVL.bfbJogJogBackward, // по часовой (- ServoControl.LrPosition_readActPos) ВВЕРХ
	Velocity:= lrfbJogVelocity, 
	Acceleration:= lrfbJogAcceleration, 
	Deceleration:= lrfbJogDeceleration, 
	Jerk:= lrfbJogJerk, 
	Busy=&gt; bfbJogBusy, 
	CommandAborted=&gt; , 
	Error=&gt; , 
	ErrorId=&gt; );
	
	

	END_IF

	
	</xhtml>
              </ST>
            </body>
