    <pous>
      <pou name="Sensors" pouType="program">
        <interface>
          <localVars>
            <variable name="LIN_TRAFO">
              <type>
                <derived name="LIN_TRAFO" />
              </type>
            </variable>
            <variable name="fbFtMinMax">
              <type>
                <derived name="OSCAT_BASIC.FT_MIN_MAX" />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">//////////fbFtMinMax/////////////////////////////</xhtml>
              </documentation>
            </variable>
            <variable name="fbFtMinMax2">
              <type>
                <derived name="OSCAT_BASIC.FT_MIN_MAX" />
              </type>
            </variable>
            <variable name="bbtn_reset_FtMinMax">
              <type>
                <BOOL />
              </type>
            </variable>
            <variable name="rMin_FtMinMax">
              <type>
                <REAL />
              </type>
            </variable>
            <variable name="rMax_FtMinMax">
              <type>
                <REAL />
              </type>
            </variable>
            <variable name="out_FORCE">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">В Н(Ньютонах)</xhtml>
              </documentation>
            </variable>
            <variable name="out_FORCE_in_H">
              <type>
                <REAL />
              </type>
            </variable>
            <variable name="blink">
              <type>
                <derived name="blink" />
              </type>
            </variable>
            <variable name="rMax_out_FORCE_in_H">
              <type>
                <REAL />
              </type>
            </variable>
            <variable name="rMin_out_FORCE_in_H">
              <type>
                <REAL />
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">///////////////////////////////////////////////////////////////////////////////	
	//Выставляем датчик силы в ноль
	LIN_TRAFO(
	IN:= GVL.PAI_F1_FORCE_A5, 
	IN_MIN:= rMin_FtMinMax, 
	IN_MAX:= 16383, 
	OUT_MIN:= 0, 
	OUT_MAX:= 5000, 
	OUT=&gt; out_FORCE , 
	ERROR=&gt; );
	
	out_FORCE_in_H := out_FORCE * 10;   //Показания датчика силы в Н(Ньютонах)
	
	//Вычисляем минимальное значение сырых данных с датчика силы
	fbFtMinMax(      
	IN :=  GVL.PAI_F1_FORCE_A5,
	RST := bbtn_reset_FtMinMax,
	mx =&gt; rMax_FtMinMax,
	mn =&gt; rMin_FtMinMax);
//////////////////////////////////////////////////////////////////////////////////
//Вычисляем экстремумы датчика силы при работе по синусу
	blink(ENABLE := TRUE, TIMELOW := T#1S, TIMEHIGH := T#1S);

	fbFtMinMax2(      
	IN :=  out_FORCE_in_H,
	RST := blink.OUT,
	mx =&gt; rMax_out_FORCE_in_H,
	mn =&gt; rMin_out_FORCE_in_H);
</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
